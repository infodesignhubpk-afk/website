# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.designhub.com.pk

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable GA.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (the meta-tag value, not the full tag).
NEXT_PUBLIC_GSC_VERIFICATION=

# WhatsApp number in international format with no spaces or pluses (e.g. 923001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# Public phone (full international, with +). Used for tel: links.
NEXT_PUBLIC_PHONE=+923001234567

# Public email
NEXT_PUBLIC_EMAIL=hello@designhub.pk

# Webhook URL for incoming leads (Zapier, Make, n8n, custom). Leave blank in dev to log to console only.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Admin passcode used to log into /admin
ADMIN_PASSCODE=

# Cloudflare R2 (S3-compatible) — used for media uploads (images, logos, favicons)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
# Public URL base for objects (R2 Public dev URL or your custom domain)
R2_PUBLIC_BASE_URL=

# Cloudflare D1 — used for admin-managed content (site/SEO settings, blogs, products, categories, orders)
# Account ID is the same as R2_ACCOUNT_ID; included separately for clarity
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
# API token with "D1: Edit" permission on this database
CLOUDFLARE_API_TOKEN=
